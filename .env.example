APP_NAME="OMM Scholar Eval"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=cookie
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync

CACHE_STORE=file

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@omm-se.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── REDCap ────────────────────────────────────────────────────────────────────
REDCAP_URL=https://comresearchdata.nyit.edu/redcap/api/
# Destination project token — permanent (OMMScholarEvalList, never changes)
REDCAP_TOKEN=
# Source project token — update each academic year when a new evaluation project is created
REDCAP_SOURCE_TOKEN=
# Shared secret appended as ?token= to the REDCap Data Entry Trigger URL.
# Generate with: openssl rand -hex 32
# Leave empty to disable verification in local/CI environments.
WEBHOOK_SECRET=

# ── Docker Hub (used by docker-compose.prod.yml) ──────────────────────────────
DOCKERHUB_USERNAME=

VITE_APP_NAME="${APP_NAME}"
