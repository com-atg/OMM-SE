APP_NAME="OMM Scholar Eval"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ── Database ──────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=mysql
DB_PORT=3306
DB_DATABASE=omm_se
DB_USERNAME=omm_se
DB_PASSWORD=secret
# Root password used by the docker-compose MySQL service.
MYSQL_ROOT_PASSWORD=secret

# ── Session / Cache / Queue ───────────────────────────────────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database

# ── Mail ──────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@omm-se.local"
MAIL_FROM_NAME="${APP_NAME}"

# ── REDCap ────────────────────────────────────────────────────────────────────
REDCAP_URL=https://comresearchdata.nyit.edu/redcap/api/
# Destination project token — permanent (OMMScholarEvalList, never changes)
REDCAP_TOKEN=
# Source project token — update each academic year when a new evaluation project is created
REDCAP_SOURCE_TOKEN=
# Shared secret appended as ?token= to the REDCap Data Entry Trigger URL.
# Generate with: openssl rand -hex 32
# Leave empty to disable verification in local/CI environments.
WEBHOOK_SECRET=
# Per-source project API tokens used when processing a PID.
# Example: REDCAP_TOKEN_PID_1846=

# ── Okta SAML SSO ─────────────────────────────────────────────────────────────
# Obtain these from the Okta application's "Sign On" → "View SAML setup instructions".
SAML_IDP_ENTITY_ID=
SAML_IDP_SSO_URL=
SAML_IDP_SLO_URL=
SAML_IDP_X509_CERT=
# This app's SP identifiers. entityId conventionally matches the metadata URL.
SAML_SP_ENTITY_ID="${APP_URL}/saml/metadata"
SAML_SP_ACS_URL="${APP_URL}/saml/acs"
SAML_SP_SLO_URL="${APP_URL}/saml/logout"
# Optional — only needed if you enable signed AuthnRequests or encrypted assertions.
SAML_SP_X509_CERT=
SAML_SP_PRIVATE_KEY=
# SAML assertion attribute names. Match these to the Okta app's attribute statements.
SAML_ATTR_EMAIL=email
SAML_ATTR_NAME=displayName
SAML_STRICT=true
SAML_DEBUG=false
SAML_DEFAULT_REDIRECT=/

# ── Docker Hub (used by docker-compose.prod.yml) ──────────────────────────────
DOCKERHUB_USERNAME=

VITE_APP_NAME="${APP_NAME}"
